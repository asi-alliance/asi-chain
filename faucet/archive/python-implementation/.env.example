# ASI Chain Faucet Environment Configuration
# Copy this file to .env and configure your settings

# ===== REQUIRED CONFIGURATION =====
# Private key for the faucet account (hex format, without 0x prefix)
FAUCET_PRIVATE_KEY=your_private_key_here

# ===== NETWORK CONFIGURATION =====
# F1R3FLY Validator Node (for sending transactions)
VALIDATOR_URL=http://18.142.221.192:40413

# F1R3FLY Read-Only Node (for balance queries)  
READONLY_URL=http://18.142.221.192:40453

# Hasura GraphQL Endpoint (optional)
GRAPHQL_URL=http://18.142.221.192:8080/v1/graphql

# ===== FAUCET SETTINGS =====
# Amount of REV tokens to distribute per request
FAUCET_AMOUNT=100

# Transaction limits (dust units)
PHLO_LIMIT=500000
PHLO_PRICE=1

# ===== SECURITY CONFIGURATION =====
# Google reCAPTCHA v2 keys (optional, leave empty to disable)
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=

# ===== DATABASE CONFIGURATION =====
# SQLite database file path
DATABASE_PATH=./faucet.db

# ===== EXAMPLE CONFIGURATION =====
# For production deployment with the funded test account:
# FAUCET_PRIVATE_KEY=357cdc4201a5650830e0bc5a03299a30038d9934ba4c7ab73ec164ad82471ff9
# VALIDATOR_URL=http://18.142.221.192:40413
# READONLY_URL=http://18.142.221.192:40453
# FAUCET_AMOUNT=100