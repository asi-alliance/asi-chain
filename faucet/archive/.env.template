# ASI Chain Testnet Faucet Configuration

# Faucet wallet private key (KEEP SECRET!)
FAUCET_PRIVATE_KEY=your_private_key_here

# RPC endpoint
RPC_URL=http://localhost:8545

# Amount to send per request (in ASI tokens)
FAUCET_AMOUNT=10

# Google reCAPTCHA secret key (optional but recommended)
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_here

# Database path
DATABASE_PATH=./faucet.db

# Flask configuration
FLASK_ENV=production
FLASK_DEBUG=False