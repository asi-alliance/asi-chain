# Development Dockerfile for ASI Wallet v2
# This runs the development server with hot-reload

FROM node:18-alpine

# Set working directory
WORKDIR /app

# Install dependencies for building native modules
RUN apk add --no-cache python3 make g++

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install --legacy-peer-deps

# Copy source code
COPY . .

# Expose port 3000
EXPOSE 3000

# Set environment variables
ENV REACT_APP_WALLETCONNECT_PROJECT_ID=4c8ec18817ffbbce4b824f14928d0f8b
ENV REACT_APP_RCHAIN_HTTP_URL=http://host.docker.internal:40403
ENV REACT_APP_RCHAIN_GRPC_URL=http://host.docker.internal:40401
ENV REACT_APP_RCHAIN_READONLY_URL=http://host.docker.internal:40403

# Start development server
CMD ["npm", "start"]