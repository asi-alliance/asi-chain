# ASI Wallet v2 Environment Configuration
# Copy this file to .env and fill in your values

# Application
NODE_ENV=production
PORT=3000

# API Configuration
REACT_APP_API_URL=http://localhost:8000/api
REACT_APP_WS_URL=ws://localhost:8000/ws

# WalletConnect Configuration
REACT_APP_WALLETCONNECT_PROJECT_ID=your_project_id_here
REACT_APP_WALLETCONNECT_RELAY_URL=wss://relay.walletconnect.com

# Security
REACT_APP_ENCRYPTION_KEY=generate_strong_key_here
REACT_APP_JWT_SECRET=generate_jwt_secret_here
REACT_APP_AUTH_TOKEN=your_auth_token_here

# ASI Chain Network
REACT_APP_CHAIN_ID=1234
REACT_APP_CHAIN_NAME=ASI Chain Testnet
REACT_APP_RPC_URL=https://rpc.asi-chain.com
REACT_APP_EXPLORER_URL=https://explorer.asi-chain.com

# Features
REACT_APP_ENABLE_TESTNET=true
REACT_APP_ENABLE_MAINNET=false

# Analytics (Optional)
REACT_APP_GA_TRACKING_ID=
REACT_APP_SENTRY_DSN=

# Rate Limiting
REACT_APP_RATE_LIMIT_REQUESTS=100
REACT_APP_RATE_LIMIT_WINDOW_MS=60000