# Docker Environment Configuration for ASI Wallet v2

# WalletConnect Project ID
# Get your own at: https://cloud.walletconnect.com
WALLETCONNECT_PROJECT_ID=4c8ec18817ffbbce4b824f14928d0f8b

# RChain Network Configuration
# For local RChain node on host machine:
RCHAIN_HTTP_URL=http://host.docker.internal:40403
RCHAIN_GRPC_URL=http://host.docker.internal:40401
RCHAIN_READONLY_URL=http://host.docker.internal:40403

# For remote RChain node:
# RCHAIN_HTTP_URL=http://your-rchain-node.com:40403
# RCHAIN_GRPC_URL=http://your-rchain-node.com:40401
# RCHAIN_READONLY_URL=http://your-rchain-node.com:40403

# For RChain nodes in Docker network:
# RCHAIN_HTTP_URL=http://rnode.readonly:40403
# RCHAIN_GRPC_URL=http://rnode.bootstrap:40401
# RCHAIN_READONLY_URL=http://rnode.readonly:40403