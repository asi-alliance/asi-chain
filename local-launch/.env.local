# ==========================================================================
# NETWORK CONFIGURATION
# ==========================================================================
NETWORK_ID=asichain-devnet
SHARD_NAME=root
FINALIZATION_RATE=1
MAX_CONNECTIONS=500

# ==========================================================================
# SERVICE PORTS (defaults shown, can be customized)
# ==========================================================================
#  Bootstrap
BOOTSTRAP_PROTOCOL_PORT=40400
BOOTSTRAP_DISCOVERY_PORT=40404
BOOTSTRAP_HTTP_PORT=40403
BOOTSTRAP_GRPC_PORT=40402

# Validator 1
VALIDATOR1_PROTOCOL_PORT=40410
VALIDATOR1_HTTP_PORT=40413

# Validator 2
VALIDATOR2_PROTOCOL_PORT=40420
VALIDATOR2_HTTP_PORT=40423

# Validator 3
VALIDATOR3_PROTOCOL_PORT=40430
VALIDATOR3_HTTP_PORT=40433

# Observer
OBSERVER_PROTOCOL_PORT=40440
OBSERVER_HTTP_PORT=40443


NODE_URL=172.25.0.10
NODE_HOST=172.25.0.10
HTTP_PORT=40413
GRPC_PORT=40412

HASURA_URL=http://localhost:8080/v1/graphql

DATABASE_POOL_SIZE=20

DATABASE_URL=postgresql://indexer:indexer_pass@postgres:5432/asichain
DATABASE_LOCAL_URL=postgresql://indexer:indexer_pass@localhost:5432/asichain

RUST_CLI_PATH=/usr/local/bin/snetrc


SYNC_INTERVAL=5
BATCH_SIZE=50
START_FROM_BLOCK=0


ENABLE_REV_TRANSFER_EXTRACTION=true
ENABLE_METRICS=true
ENABLE_HEALTH_CHECK=true
LOG_LEVEL=INFO
LOG_FORMAT=json

# Hasura
HASURA_ADMIN_SECRET=myadminsecretkey
HASURA_BASE=http://localhost:8080

HASURA_ENDPOINT=http://localhost:8080/v1/metadata
HASURA_GRAPHQL=http://localhost:8080/v1/graphql
HASURA_SQL=http://localhost:8080/v2/query

HASURA_GRAPHQL_UNAUTHORIZED_ROLE=public
HASURA_GRAPHQL_ENABLED_APIS=graphql,metrics