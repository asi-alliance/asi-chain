# F1R3FLY Stress Test Log Rotation Configuration
# Copy to /etc/logrotate.d/f1r3fly-stress-tests

/var/log/f1r3fly/stress_tests/*.log {
    daily
    rotate 30
    compress
    delaycompress
    missingok
    notifempty
    create 644 ubuntu ubuntu
    dateext
    dateformat -%Y%m%d
    
    # Run post-rotation script to update metrics
    postrotate
        # Update last rotation timestamp
        echo "f1r3fly_stress_test_logs_rotated $(date +%s)" > /var/lib/prometheus/node-exporter/f1r3fly_log_rotation.prom
    endscript
}

/var/log/f1r3fly/stress_tests/cron.log {
    weekly
    rotate 4
    compress
    delaycompress
    missingok
    notifempty
    create 644 ubuntu ubuntu
}