# ASI Chain Explorer Environment Configuration

# GraphQL Endpoint (Hasura)
REACT_APP_GRAPHQL_URL=http://localhost:8080/v1/graphql
REACT_APP_GRAPHQL_WS_URL=ws://localhost:8080/v1/graphql

# Hasura Admin Secret
REACT_APP_HASURA_ADMIN_SECRET=myadminsecretkey

# Development Settings
REACT_APP_ENVIRONMENT=development
REACT_APP_API_TIMEOUT=30000

# Optional: Custom branding
REACT_APP_BRAND_NAME="ASI Chain Explorer"
REACT_APP_BRAND_SUBTITLE="Powered by GraphQL"